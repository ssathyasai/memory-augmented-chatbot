# Application Settings
APP_NAME="Memory-Augmented Chatbot"
DEBUG=False

# Security
JWT_SECRET_KEY="your-super-secret-jwt-key-min-32-characters-long"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_HOURS=24
PASSWORD_MIN_LENGTH=8

# MongoDB Configuration
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="chatbot_db"

# Neo4j Configuration
NEO4J_URI="neo4j+s://xxxxx.databases.neo4j.io"
NEO4J_USER="your-instance-id"
NEO4J_PASSWORD="your-neo4j-password"
NEO4J_DATABASE="your-instance-id"

# GROQ API
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxx"
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.7

# Embeddings
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSION=384

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=8
SIMILARITY_THRESHOLD=0.25
MAX_CONTEXT_TOKENS=4000

# Vector Store
VECTOR_STORE_TYPE="faiss"
VECTOR_STORE_PATH="./vector_stores"

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=".pdf,.docx,.txt,.md"

# Rate Limiting
MAX_QUERIES_PER_MINUTE=30
MAX_DOCUMENTS_PER_USER=100
MAX_STORAGE_MB_PER_USER=500
